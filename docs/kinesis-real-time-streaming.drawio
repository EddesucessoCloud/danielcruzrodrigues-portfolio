        <mxCell id="edge-iot-kds" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1A9C37;strokeWidth=2;fontFamily=Helvetica;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.15;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-iot" target="svc-kds">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-apigw-kds" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontFamily=Helvetica;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.38;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-apigw" target="svc-kds">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-ec2-kds" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#ED7100;strokeWidth=2;fontFamily=Helvetica;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.62;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-ec2" target="svc-kds">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-dms-kds" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=2;fontFamily=Helvetica;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.85;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-dms" target="svc-kds">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== EDGES: KDS fan-out to consumers ===== -->
        <mxCell id="edge-kds-lambda" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#ED7100;strokeWidth=2.5;fontFamily=Helvetica;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-kds" target="svc-lambda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-kds-firehose" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#8C4FFF;strokeWidth=2.5;fontFamily=Helvetica;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-kds" target="svc-firehose">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-kds-kda" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#8C4FFF;strokeWidth=2.5;fontFamily=Helvetica;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-kds" target="svc-kda">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== EDGES: Hot path ===== -->
        <mxCell id="edge-lambda-ddb" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#C925D1;strokeWidth=2;fontFamily=Helvetica;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-lambda" target="svc-dynamodb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-lambda-sqs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#E7157B;strokeWidth=2;dashed=1;fontFamily=Helvetica;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-lambda" target="svc-sqs">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl-lambda-sqs" value="on failure" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=none;fontSize=10;fontStyle=2;fontFamily=Helvetica;" connectable="0" vertex="1" parent="edge-lambda-sqs">
          <mxGeometry relative="1" x="0.3" y="0" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ===== EDGES: Warm path ===== -->
        <mxCell id="edge-firehose-s3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3F8624;strokeWidth=2;fontFamily=Helvetica;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-firehose" target="svc-s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lbl-firehose-s3" value="128 MB / 300s" style="edgeLabel;html=1;align=center;verticalAlign=middle;resizable=0;points=[];labelBackgroundColor=none;fontSize=10;fontStyle=2;fontFamily=Helvetica;" connectable="0" vertex="1" parent="edge-firehose-s3">
          <mxGeometry relative="1" x="0" y="-15" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="edge-s3-glue" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontFamily=Helvetica;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-s3" target="svc-glue">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== EDGES: Analytical path ===== -->
        <mxCell id="edge-kda-redshift" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontFamily=Helvetica;exitX=1;exitY=0.25;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-kda" target="svc-redshift">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge-kda-opensearch" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#8C4FFF;strokeWidth=2;fontFamily=Helvetica;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="svc-kda" target="svc-opensearch">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== STEP BADGES (on-diagram) ===== -->
        <mxCell id="badge-1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="1" vertex="1" parent="1">
          <mxGeometry x="415" y="250" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="badge-2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="2" vertex="1" parent="1">
          <mxGeometry x="650" y="370" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="badge-3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="3" vertex="1" parent="1">
          <mxGeometry x="743" y="163" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="badge-4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="4" vertex="1" parent="1">
          <mxGeometry x="1013" y="163" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="badge-5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="5" vertex="1" parent="1">
          <mxGeometry x="743" y="345" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="badge-6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="6" vertex="1" parent="1">
          <mxGeometry x="650" y="615" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="badge-7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="7" vertex="1" parent="1">
          <mxGeometry x="1013" y="563" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="badge-8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="8" vertex="1" parent="1">
          <mxGeometry x="650" y="840" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="badge-9" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=16;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;align=center;verticalAlign=middle;labelBackgroundColor=none;" value="9" vertex="1" parent="1">
          <mxGeometry x="1013" y="763" width="28" height="28" as="geometry" />
        </mxCell>

        <!-- ===== LEGEND PANEL ===== -->
        <mxCell id="legend-bg" style="verticalLabelPosition=bottom;verticalAlign=top;html=1;shape=mxgraph.basic.rect;fillColor2=none;strokeWidth=1;size=20;indent=5;fillColor=light-dark(#EDF3FF,#305363);strokeColor=#6c8ebf;" value="" vertex="1" parent="1">
          <mxGeometry height="1080" width="650" x="1540" y="30" as="geometry" />
        </mxCell>
        <mxCell id="legend-hdr" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;fontFamily=Helvetica;labelBackgroundColor=none;" value="Architecture Steps" vertex="1" parent="1">
          <mxGeometry height="30" width="600" x="1560" y="58" as="geometry" />
        </mxCell>

        <!-- Step 1 -->
        <mxCell id="s1g" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="95" width="608" x="1556" y="98" as="geometry" />
        </mxCell>
        <mxCell id="s1b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="1" vertex="1" parent="s1g">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="s1d" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Ingest Events from Data Sources&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;IoT Core (MQTT/HTTP), API Gateway (clickstream SDK), application servers (PutRecord API), and DMS (CDC replication) all publish records into Kinesis Data Streams shards.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="s1g">
          <mxGeometry height="95" width="555" x="52" as="geometry" />
        </mxCell>

        <!-- Step 2 -->
        <mxCell id="s2g" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="80" width="608" x="1556" y="200" as="geometry" />
        </mxCell>
        <mxCell id="s2b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="2" vertex="1" parent="s2g">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="s2d" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;KDS Fan-Out to 3 Consumer Groups&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Kinesis Data Streams simultaneously delivers records to Lambda ESM (hot), Kinesis Firehose (warm), and Managed Apache Flink (analytical) - each group reads independently.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="s2g">
          <mxGeometry height="80" width="555" x="52" as="geometry" />
        </mxCell>

        <!-- Step 3 -->
        <mxCell id="s3g" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="80" width="608" x="1556" y="288" as="geometry" />
        </mxCell>
        <mxCell id="s3b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="3" vertex="1" parent="s3g">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="s3d" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Hot Path: Lambda ESM (p99 &amp;lt; 500ms)&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Lambda polls KDS via Event Source Mapping. The batchItemFailures response enables per-record retry - failed records are retried up to 3x without blocking the shard.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="s3g">
          <mxGeometry height="80" width="555" x="52" as="geometry" />
        </mxCell>

        <!-- Step 4 -->
        <mxCell id="s4g" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="70" width="608" x="1556" y="376" as="geometry" />
        </mxCell>
        <mxCell id="s4b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="4" vertex="1" parent="s4g">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="s4d" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Write Processed Events to DynamoDB&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Successfully processed events are stored in DynamoDB for real-time access, downstream API serving, and alerting with single-digit millisecond reads.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="s4g">
          <mxGeometry height="70" width="555" x="52" as="geometry" />
        </mxCell>

        <!-- Step 5 -->
        <mxCell id="s5g" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="70" width="608" x="1556" y="454" as="geometry" />
        </mxCell>
        <mxCell id="s5b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="5" vertex="1" parent="s5g">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="s5d" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Poison-Pill Isolation via SQS DLQ&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Records that fail all retries are routed to the SQS Dead Letter Queue. This isolates corrupt messages and unblocks the shard for healthy records.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="s5g">
          <mxGeometry height="70" width="555" x="52" as="geometry" />
        </mxCell>

        <!-- Step 6 -->
        <mxCell id="s6g" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="85" width="608" x="1556" y="532" as="geometry" />
        </mxCell>
        <mxCell id="s6b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="6" vertex="1" parent="s6g">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="s6d" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Warm Path: Firehose Delivers to S3 Bronze&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Kinesis Firehose buffers events (128 MB or 300s), applies JQ-based dynamic partitioning by event type and timestamp, and delivers GZIP-compressed Parquet files to S3 bronze zone.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="s6g">
          <mxGeometry height="85" width="555" x="52" as="geometry" />
        </mxCell>

        <!-- Step 7 -->
        <mxCell id="s7g" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="75" width="608" x="1556" y="625" as="geometry" />
        </mxCell>
        <mxCell id="s7b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="7" vertex="1" parent="s7g">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="s7d" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;AWS Glue: Bronze to Silver Transformation&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Glue ETL jobs read partitioned S3 bronze data, apply schema enforcement, data quality rules, and deduplication, writing validated Delta Lake format to the silver zone.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="s7g">
          <mxGeometry height="75" width="555" x="52" as="geometry" />
        </mxCell>

        <!-- Step 8 -->
        <mxCell id="s8g" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="80" width="608" x="1556" y="708" as="geometry" />
        </mxCell>
        <mxCell id="s8b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="8" vertex="1" parent="s8g">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="s8d" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Analytical Path: Flink Windowed Aggregations&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Managed Apache Flink reads directly from KDS, performs tumbling and sliding window aggregations, and writes derived streams to Redshift and OpenSearch for analytics.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="s8g">
          <mxGeometry height="80" width="555" x="52" as="geometry" />
        </mxCell>

        <!-- Step 9 -->
        <mxCell id="s9g" connectable="0" style="group;fontFamily=Helvetica;" value="" vertex="1" parent="1">
          <mxGeometry height="80" width="608" x="1556" y="796" as="geometry" />
        </mxCell>
        <mxCell id="s9b" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=default;fontColor=#FFFFFF;fontStyle=1;fontSize=22;labelBackgroundColor=none;fontFamily=Helvetica;shadow=1;glass=0;strokeWidth=2;" value="9" vertex="1" parent="s9g">
          <mxGeometry height="38" width="40" y="2" as="geometry" />
        </mxCell>
        <mxCell id="s9d" style="text;html=1;align=left;verticalAlign=top;spacingTop=-4;fontSize=13;labelBackgroundColor=none;whiteSpace=wrap;fontFamily=Helvetica;" value="&lt;div&gt;&lt;b&gt;Serve Analytical Queries&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: light-dark(rgb(0,0,0), rgb(255,255,255));&quot;&gt;Amazon Redshift serves OLAP and BI queries with sub-second response. OpenSearch powers real-time search, log analytics, and operational dashboards for engineering and business teams.&lt;/span&gt;&lt;/div&gt;" vertex="1" parent="s9g">
          <mxGeometry height="80" width="555" x="52" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
