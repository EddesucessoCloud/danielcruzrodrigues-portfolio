          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Outcome: Superseded -->
        <mxCell id="node-superseded" value="&lt;b&gt;Superseded&lt;/b&gt;&lt;br/&gt;&lt;font style=&quot;font-size:10px;&quot;&gt;Status = Superseded&lt;br/&gt;New ADR required&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a1a;strokeColor=#6B7280;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;fontFamily=Helvetica;arcSize=12;" vertex="1" parent="1">
