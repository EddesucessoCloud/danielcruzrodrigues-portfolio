          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Loop back: Superseded to Step 1 -->
        <mxCell id="arrow-loop-back" value="New ADR triggered" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6B7280;strokeWidth=1.5;dashed=1;dashPattern=8 4;fillColor=#6B7280;fontSize=10;fontColor=#9CA3AF;fontFamily=Helvetica;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="node-superseded" target="node-trigger" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="160" y="595" />
              <mxPoint x="160" y="650" />
              <mxPoint x="160" y="700" />
            </Array>
          </mxGeometry>
