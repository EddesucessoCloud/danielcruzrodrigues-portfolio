        <!-- LEGEND PANEL -->
        <mxCell id="legend-panel" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f1824;strokeColor=#2d4a6e;strokeWidth=2;arcSize=3;" vertex="1" parent="1">
          <mxGeometry x="1560" y="20" width="670" height="860" as="geometry" />
        </mxCell>
        <mxCell id="legend-title" value="Step Reference" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;fontColor=#E8F4FD;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1560" y="40" width="670" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend-divider" value="" style="line;strokeColor=#2d4a6e;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1580" y="80" width="630" height="10" as="geometry" />
        </mxCell>

        <!-- Legend entry 1 -->
        <mxCell id="legend-badge-1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=#005a8e;fontColor=#FFFFFF;fontSize=12;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1585" y="110" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend-title-1" value="TRIGGER" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#007CBD;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="108" width="580" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-desc-1" value="A new architectural decision is needed: choosing a table format (Delta vs Iceberg), selecting an orchestrator (Airflow vs Prefect), or evaluating streaming vs batch ingestion. The team identifies the need and assigns an engineer to draft the ADR." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#8B9FBA;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="130" width="585" height="70" as="geometry" />
        </mxCell>

        <!-- Legend entry 2 -->
        <mxCell id="legend-badge-2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=#005a8e;fontColor=#FFFFFF;fontSize=12;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1585" y="218" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend-title-2" value="DRAFT ADR" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#4A90D9;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="216" width="580" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-desc-2" value="Engineer creates an ADR markdown file capturing: Context (why this decision exists), Options Considered (2+ alternatives), Trade-offs Matrix (pros/cons table), Decision (the chosen option), and Consequences (impact on the system). Stored in /docs/adr/ and tracked in git." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#8B9FBA;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="238" width="585" height="70" as="geometry" />
        </mxCell>

        <!-- Legend entry 3 -->
        <mxCell id="legend-badge-3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=#005a8e;fontColor=#FFFFFF;fontSize=12;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1585" y="326" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend-title-3" value="REVIEW" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#D4A017;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="324" width="580" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-desc-3" value="The ADR is submitted as a Pull Request. Tech Lead and peers review the trade-off analysis. If the analysis is incomplete or the decision is contested, the PR is rejected and the engineer revises. Once reasoning is sound and the team aligns, the PR is approved." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#8B9FBA;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="346" width="585" height="70" as="geometry" />
        </mxCell>

        <!-- Legend entry 4 -->
        <mxCell id="legend-badge-4" value="4" style="ellipse;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=#005a8e;fontColor=#FFFFFF;fontSize=12;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1585" y="434" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend-title-4" value="ACCEPTED AND IMPLEMENTED" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#22C55E;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="432" width="580" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-desc-4" value="The decision is implemented in the codebase. The ADR file header is updated to status: Accepted. The document now serves as the authoritative record explaining why the architecture is the way it is, protecting the team from revisiting settled debates." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#8B9FBA;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="454" width="585" height="70" as="geometry" />
        </mxCell>

        <!-- Legend entry 5 -->
        <mxCell id="legend-badge-5" value="5" style="ellipse;whiteSpace=wrap;html=1;fillColor=#007CBD;strokeColor=#005a8e;fontColor=#FFFFFF;fontSize=12;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1585" y="542" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="legend-title-5" value="LIVING DOCUMENT" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=13;fontStyle=1;fontColor=#A78BFA;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="540" width="580" height="20" as="geometry" />
        </mxCell>
        <mxCell id="legend-desc-5" value="ADRs are reviewed as the system evolves. If the original decision still holds, the ADR is archived. If context has changed or a better option emerges, the ADR is marked Superseded and a new ADR is created, maintaining a full audit trail of decisions over time." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#8B9FBA;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="1625" y="562" width="585" height="70" as="geometry" />
        </mxCell>

